# ============================================================
# MyProdusen — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# ── Database (PostgreSQL) ──────────────────────────────────────
# For Coolify: use the internal service URL from Coolify DB panel
DATABASE_URL="postgresql://myprodusen_user:STRONG_PASSWORD_HERE@postgres:5432/myprodusen"

# ── Redis Cache ────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"
REDIS_PASSWORD=""
REDIS_DB="0"
REDIS_MAX_RETRIES="3"
CACHE_ENABLED="true"
CACHE_DEFAULT_TTL="300"

# ── JWT Secret (MUST change for production — min 32 chars) ─────
# Generate with: openssl rand -base64 48
JWT_SECRET="CHANGE_THIS_TO_RANDOM_32_PLUS_CHARACTER_SECRET_IN_PRODUCTION"

# ── App ────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://myprodusen.online"
APP_URL="https://myprodusen.online"

# ── Upload Storage ─────────────────────────────────────────────
UPLOAD_DIR="/app/uploads"
MAX_UPLOAD_SIZE="5242880"

# ── Geo-fencing ────────────────────────────────────────────────
DEFAULT_GEOFENCE_RADIUS=100

# ── Session ────────────────────────────────────────────────────
SESSION_TIMEOUT_HOURS=8

# ── Superadmin Bootstrap ───────────────────────────────────────
# Used only on first deploy to create the initial superadmin user
SUPERADMIN_EMAIL="produsendimsumm@gmail.com"
SUPERADMIN_USERNAME="superadmin"
SUPERADMIN_PASSWORD="CHANGE_THIS_STRONG_PASSWORD_MIN_12_CHARS"

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="MyProdusen <noreply@myprodusen.online>"

# ── Performance ────────────────────────────────────────────────
NODE_OPTIONS="--max-old-space-size=2048"
NEXT_TELEMETRY_DISABLED=1
