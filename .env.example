# Database
DATABASE_URL="postgresql://user:password@localhost:5432/myprodusen?schema=public"

# Redis Cache
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"
REDIS_MAX_RETRIES="3"
CACHE_ENABLED="true"
CACHE_DEFAULT_TTL="300"

# JWT Secret (MUST be changed for production - minimum 32 characters)
JWT_SECRET="CHANGE_THIS_TO_RANDOM_32_PLUS_CHARACTER_SECRET_IN_PRODUCTION"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upload Storage
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE="5242880"

# Geo-fencing
DEFAULT_GEOFENCE_RADIUS=100

# Session
SESSION_TIMEOUT_HOURS=8

# Production bootstrap only; remove or change before production
# SUPERADMIN_EMAIL="admin@example.com"
# SUPERADMIN_PASSWORD="change-this-before-production"
