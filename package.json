{
  "name": "myprodusen",
  "version": "1.0.0",
  "description": "Employee Management System for Produsen Dimsum Medan",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run build:next",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:deploy": "node scripts/run-migrations.mjs",
    "db:push": "drizzle-kit push",
    "db:push:prod": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} drizzle/seed.ts",
    "perf:explain": "node scripts/explain-attendance-queries.mjs",
    "release:env": "node scripts/check-production-env.mjs",
    "release:migrations": "node scripts/check-migrations-coverage.mjs",
    "release:check": "npm run lint && npm run test && npm run build && npm run release:migrations",
    "release:check:full": "npm run release:check && npm run release:env",
    "bootstrap:superadmin": "node scripts/bootstrap-superadmin.mjs",
    "start:prod": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} sh -c 'if [ -f server.js ]; then exec node server.js; fi; exec node .next/standalone/server.js'",
    "dev:safe": "next dev --webpack",
    "clean": "rm -rf .next tsconfig.tsbuildinfo node_modules/.cache",
    "build:next": "node scripts/build-next-with-heartbeat.mjs",
    "dev:mobile": "next dev -H 0.0.0.0 -p 3000",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "android:live": "bash scripts/android-live-preview.sh",
    "android:install-live": "bash scripts/android-install-live.sh",
    "android:realtime": "bash scripts/sync-android-realtime.sh"
  },
  "keywords": [
    "attendance",
    "kpi",
    "employee-management"
  ],
  "author": "Produsen Dimsum Medan",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.64.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^2.4.3",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "postcss": "^8.5.14",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.54.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "workbox-webpack-plugin": "^7.4.1",
    "workbox-window": "^7.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "fake-indexeddb": "^6.2.5",
    "ts-node": "^10.9.2",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "postcss": "^8.5.14"
  }
}
