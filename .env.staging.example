# Staging stack secrets for docker-compose.staging.yml.
# Copy to .env.staging (gitignored) and fill in. These are LOCAL/STAGING-ONLY
# values — never reuse production secrets here.
#
#   cp .env.staging.example .env.staging

# Database (used to compose DATABASE_URL for the app)
STAGING_DB_USER=myprodusen
STAGING_DB_PASSWORD=change-me-staging-db-password
STAGING_DB_NAME=myprodusen_staging

# App host port (http://localhost:<port>)
STAGING_APP_PORT=3100

# Auth secrets — must each be at least 32 characters.
# Generate: openssl rand -base64 48
STAGING_JWT_SECRET=change-me-at-least-32-characters-long-staging
STAGING_NEXTAUTH_SECRET=change-me-at-least-32-characters-long-staging

# Optional: auto-bootstrap a superadmin on first boot (password >= 12 chars).
# Leave blank to skip bootstrap and seed manually.
STAGING_SUPERADMIN_EMAIL=admin@staging.local
STAGING_SUPERADMIN_PASSWORD=change-me-staging-admin

# Optional toggles
STAGING_IMAGE_OPTIMIZATION_DISABLED=false
